#!/bin/bash


#arrays
declare -A COEF
declare -A PENALTY


#counters found
CRITICAL_COUNT=0
WARNING_COUNT=0
INFO_COUNT=0

# Colors ANSI codes
NC="\033[0m"
YELLOW="\x1b[33m"
RED="\x1b[31m"
GREEN="\033[32m"

# Check root
check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[-] Error: This script must be run as root!${NC}"
        exit 1
    fi
}

VULNERS_LIB="/usr/share/vulners"

source /etc/vulners/weights.conf
for check in "$VULNERS_LIB"/checks/*.sh; do
    source "$check"
done
for lib in "$VULNERS_LIB"/lib/*.sh; do 
    source "$lib"                         
done                                        




# run func
run_audit() {
  clear          
  check_root
  search_suid
  search_sgid
  world_writable 
  wwwsticky
  acl_check
  writable-units 
  check_capabilities
  empty_password
  echo_sticky_tmp
  execstart
  sudoers
  summary_print
  
}


main() {
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    -l|--log)
      check_root
      LOG_FILE="/var/log/vulners.log"
      echo -e "${YELLOW}[*] Starting security audit...${NC}"
      echo -e "${YELLOW}[*] All details will be saved to: $LOG_FILE${NC}"
      echo "------------------------------------------------"
      
      run_audit > "$LOG_FILE" 2>&1
      
      echo -e "${GREEN}[+] Audit successfully finished!${NC}"
      echo -e "${GREEN}[+] To view the results, run:${NC} cat $LOG_FILE"
      echo "------------------------------------------------"
      ;;
    "")
      run_audit
      ;;
    *)
      echo -e "${RED} Error: Unknown argument: '$1'${NC}"
      show_help
      exit 0
      ;;
  esac
}


 main "$1"
