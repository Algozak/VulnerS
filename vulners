#!/bin/bash

# Colors ANSI codes
NC="\033[0m"
YELLOW="\x1b[33m"
RED="\x1b[31m"
GREEN="\033[32m"

# Check root
check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[-] Error: This script must be run as root!${NC}"
        exit 1
    fi
}

source checks/suid.sh
source checks/sgid.sh
source checks/world_writable.sh
source checks/empty_password.sh
source checks/sticky_bit.sh
source checks/sudoers.sh
source checks/capabilities.sh
source checks/wwwsticky.sh
source checks/acl_check.sh


# run func
run_audit() {
  clear          
  check_root
  search_suid
  search_sgid
  world_writable 
  wwwsticky
  acl_check
  check_capabilities
  empty_password
  echo_sticky_tmp
  sudoers
  
}


main() {
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    -l|--log)
      LOG_FILE="/var/log/vulners.log"
      echo -e "${YELLOW}[*] Starting security audit...${NC}"
      echo -e "${YELLOW}[*] All details will be saved to: $LOG_FILE${NC}"
      echo "------------------------------------------------"
      
      run_audit > "$LOG_FILE" 2>&1

      echo -e "${GREEN}[+] Audit successfully finished!${NC}"
      echo -e "${GREEN}[+] To view the results, run:${NC} cat $LOG_FILE"
      echo "------------------------------------------------"
      ;;
    "")
      run_audit
      ;;
    *)
      echo -e "${RED} Error: Unknown argument: '$1'${NC}"
      show_help
      exit 0
      ;;
  esac
}


main "$1"
